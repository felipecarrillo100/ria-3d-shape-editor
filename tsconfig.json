{
  "compilerOptions": {
    "target": "ES6",
    "module": "es2020",
    "lib": ["es6", "dom", "dom.iterable", "es2017"],
    "declaration": true,
    "strict": false,
    "strictPropertyInitialization": false,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./node_modules",
    "./src/**/*.test.ts"
  ]
}
